# ============================================================
#  Produktions-Umgebung "personal"  (Kopiere nach: .env)
#  Auf dem Server: cp .env.production.example .env  und Werte setzen.
#  KEINE echten Secrets committen!
# ============================================================

# --- Django ---
SECRET_KEY=BITTE_LANGEN_ZUFALLSWERT_EINSETZEN
DEBUG=False
ALLOWED_HOSTS=personal.meinpflegeweg.com

# --- Datenbank (eigene, separate DB) ---
POSTGRES_DB=personal_db
POSTGRES_USER=personal_user
POSTGRES_PASSWORD=BITTE_STARKES_PASSWORT_EINSETZEN
DATABASE_URL=postgres://personal_user:BITTE_STARKES_PASSWORT_EINSETZEN@personal-postgres:5432/personal_db

# --- JWT ---
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# --- CORS / CSRF (gleiche Domain für Frontend & API) ---
CORS_ALLOWED_ORIGINS=https://personal.meinpflegeweg.com
CSRF_TRUSTED_ORIGINS=https://personal.meinpflegeweg.com

# --- Sicherheit (hinter Nginx-TLS) ---
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# --- Speicherorte (im Container; per Volume auf ./storage gemountet) ---
STORAGE_DIR=/app/storage
STATIC_ROOT=/app/storage/static
MEDIA_ROOT=/app/storage/media
INVOICE_ROOT=/app/storage/invoices
INVOICE_URL=/invoices/
LOG_DIR=/app/logs

# --- Gunicorn ---
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# --- E-Mail (SMTP, z. B. IONOS) ---
EMAIL_USE_CONSOLE=False
EMAIL_HOST=smtp.ionos.de
EMAIL_PORT=587
EMAIL_HOST_USER=infos@mouvinpersonal.de
EMAIL_HOST_PASSWORD=BITTE_SMTP_PASSWORT_EINSETZEN
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=infos@mouvinpersonal.de

# --- Frontend (Build-Zeit, in den Client gebacken) ---
NEXT_PUBLIC_API_URL=https://personal.meinpflegeweg.com/api
